# Mechanism runtime configuration.

TIMEZONE=America/Los_Angeles

DATABASE_URL=postgresql://user:password@host:5432/dbname
REDIS_URL=redis://host:6379/0

CHAT_BASE_URL=https://gateway.tail8bd569.ts.net/v1
CHAT_MODEL=Ember/qwen3.5-4b
CHAT_API_KEY=not-used-but-required
EMBEDDING_BASE_URL=https://gateway.tail8bd569.ts.net/v1
EMBEDDING_MODEL=Ember/text-embedding-qwen3-embedding-4b
EMBEDDING_API_KEY=not-used-but-required

# Bearer token for the FastMCP servers. Required — startup fails loudly if
# unset rather than silently running unauthenticated. Production sets this
# via CC's settings.local.json `env` block so the same value reaches both
# the server and the CC clients sending the bearer header.
MECHANISM_TOKEN=set-me-to-a-real-secret

# Optional: Logfire observability. LOGFIRE_TOKEN and OTEL_SERVICE_NAME are
# coupled — a model_validator refuses startup if the token is set without
# the service name. Service identity is explicit per deploy, never inferred.
# LOGFIRE_TOKEN=
# OTEL_SERVICE_NAME=
